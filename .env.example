# ─────────────────────────────────────────────────────────────────
# Environment variables for the Soleanna Run Club site.
#
# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local
#
# In production, set these in your Vercel project's
# Settings → Environment Variables. The DATABASE_URL and
# BLOB_READ_WRITE_TOKEN values are added automatically when you create
# the Neon Postgres and Vercel Blob stores in the Storage tab — pull
# them locally with `vercel env pull`.
# ─────────────────────────────────────────────────────────────────

# Password for the /admin schedule editor. Choose your own.
ADMIN_PASSWORD=changeme

# Neon Postgres connection string (schedule storage).
# Until this is set, the site shows seed data and editing is disabled.
DATABASE_URL=

# Vercel Blob read-write token (flyer image uploads).
# Required to upload event flyers from the admin.
BLOB_READ_WRITE_TOKEN=
